# Delta Environment Variables
# For local dev (Postgres)
export DBT_TARGET=dev
export POSTGRES_HOST="localhost"
export POSTGRES_USER="yucheng"
export POSTGRES_PASSWORD="poisson123"
export POSTGRES_DB=delta_dev
export POSTGRES_PORT=5432
export DBT_SCHEMA_RAW=src_byod_mitos
export DBT_SCHEMA_TRANSFORM=rpt_mitos

# For production (Snowflake)
export DBT_TARGET=prod
export SNOWFLAKE_ACCOUNT=MLWHHLL-MIT_DATALAKE_DEV
export SNOWFLAKE_USER=YU_CHENG@MIT.EDU
export SNOWFLAKE_ROLE=MITOS_ROLE
export SNOWFLAKE_DATABASE=DEV_DB
export SNOWFLAKE_WAREHOUSE=BA_WAREHOUSE

# Dagster variables
export DAGSTER_HOME=$(pwd)/.dagster
mkdir -p $DAGSTER_HOME

export DBT_PROFILES_DIR=./

# uv environment
if ! command -v uv &> /dev/null; then
    echo "uv not found, please install it: https://github.com/astral-sh/uv"
else
    source .venv/bin/activate 2>/dev/null || true
fi

